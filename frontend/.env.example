# URL do backend (obrigatório para menu e pedidos do Square)
VITE_API_URL=http://localhost:3001

# Pagamento online — escolha UM modo:
# - hosted = Payment Link (redirect para página da Square; configure CHECKOUT_SUCCESS_URL no backend).
# - inline (ou omita) = Web Payments SDK no checkout; exige VITE_SQUARE_* abaixo.
# VITE_SQUARE_CHECKOUT=hosted
#
# Web Payments SDK (modo inline): se ambos estiverem definidos, o checkout exige cartão e o backend
# chama a Payments API após criar o pedido.
# Application ID: Developer Dashboard → sua aplicação → Credentials (Sandbox vs Production).
# Location ID: o mesmo SQUARE_LOCATION_ID do backend.
# VITE_SQUARE_ENV=sandbox
# VITE_SQUARE_APPLICATION_ID=
# VITE_SQUARE_LOCATION_ID=

# Firebase (Authentication + Firestore para perfil: nome, telefone sem SMS)
# Console: https://console.firebase.google.com — criar projeto → Authentication:
#   ativar Google, Facebook, E-mail/senha. Em Firestore Database: criar DB em modo de teste
#   e depois publicar regras (só o dono do uid acessa users/{uid}) — ver firebase/firestore.rules
# Project settings → Your apps → Web → copiar os valores abaixo:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=projeto.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=projeto.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
#
# Facebook: Firebase → Authentication → Facebook → App ID e App Secret do developers.facebook.com
# Domínios autorizados: localhost e seu domínio de produção.
