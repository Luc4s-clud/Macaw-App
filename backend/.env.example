# Square (obtenha em https://developer.squareup.com/apps)
# Use Sandbox para testes; Production para loja real.
SQUARE_ACCESS_TOKEN=EAAAl7vCwxDZzWhlDkbvkwsatdtc6AeQVK3JuuLD9DnNS0LqenvL4FdX8K25W1mN
SQUARE_LOCATION_ID=L907VWHEV72A8
SQUARE_ENV=sandbox

# Opcional: Application ID (só para o frontend, no Web Payments SDK). Não coloque o token aqui.
# SQUARE_APPLICATION_ID=

# Servidor (na VPS deixe PORT igual ao proxy/nginx; HOST padrão 0.0.0.0 aceita conexões externas)
PORT=3001
# HOST=0.0.0.0
NODE_ENV=development

# Com nginx na frente, não altere: o app já usa trust proxy (1 hop) para rate-limit e X-Forwarded-For.

# CORS: origens permitidas separadas por vírgula (vazio = qualquer origem)
# Ex: http://localhost:5173,https://macawacaiteria.com
CORS_ORIGIN=

# Checkout hospedado (Payment Link): URL da página de retorno após o cliente pagar na Square.
# Deve ser a URL pública do seu site + /checkout/complete (ex.: http://localhost:5173/checkout/complete).
# CHECKOUT_SUCCESS_URL=http://localhost:5173/checkout/complete

# Webhook Square (POST recebido em /api/webhooks/square). Em produção, configure assinatura e URL idêntica ao Dashboard.
# SQUARE_WEBHOOK_SIGNATURE_KEY=
# SQUARE_WEBHOOK_NOTIFICATION_URL=https://SEU-DOMINIO/api/webhooks/square
# WEBHOOK_ALLOW_UNSIGNED=false

# Cache do GET /api/menu no backend (segundos). 0 = sem cache. Padrão: 120.
# Reduz chamadas ao Square; aumente o tempo se o cardápio mudar raramente.
# MENU_CACHE_TTL_SECONDS=120

# Log de cada requisição HTTP no console (padrão: ligado). Desligar: REQUEST_LOG=false
# REQUEST_LOG=false



